Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"LInttrapSm", "[", "f_", "]"}], "[", 
    RowBox[{"x1_", ",", "x2_"}], "]"}], "[", "n_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"dx", ",", "tab"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dx", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x2", "-", "x1"}], ")"}], "/", "n"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"tab", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"N", "[", 
         RowBox[{"f", "[", "x", "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "x1", ",", "x2", ",", "dx"}], "}"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Total", "[", "tab", "]"}], "-", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"f", "[", "x1", "]"}], "+", 
           RowBox[{"f", "[", "x2", "]"}]}], ")"}]}]}], ")"}], "*", "dx"}]}]}],
    "\[IndentingNewLine]", "]"}]}]], "InitializeFunction",
 CellChangeTimes->{{3.938656024195324*^9, 3.9386561825442157`*^9}, {
  3.938656261829317*^9, 3.938656341487834*^9}, {3.938656462517109*^9, 
