 RowBox[{
  RowBox[{"IntGboxmu", "[", 
   RowBox[{"ER_", ",", "e1_", ",", "e2_", ",", "sig_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", "sig"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"e2", "-", "ER", "+", "sig"}], ")"}], "*", 
        RowBox[{"UnitStep", "[", 
