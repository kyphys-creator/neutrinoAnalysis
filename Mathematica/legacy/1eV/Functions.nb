Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SampleIntByEdges", "[", "f_", "]"}], "[", 
   RowBox[{"edges_List", "?", "VectorQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"e", "=", "edges"}], "}"}], ",", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "e", "]"}], "<", "2"}], ",", 
       RowBox[{"Return", "[", 
        RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"StrictlyIncreasingQ", "[", "e", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"SampleIntByEdges", "::", "edges"}], 
          ",", "\"\<edges must be strictly increasing\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{"f", "[", "Ev", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"Ev", ",", 
           RowBox[{"e", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"e", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{
          RowBox[{"Length", "[", "e", "]"}], "-", "1"}]}], "}"}]}], "]"}]}]}],
    "]"}]}], "\n", 
