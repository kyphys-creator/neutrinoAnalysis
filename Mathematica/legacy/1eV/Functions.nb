     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "b"}], "}"}], ",", 
       RowBox[{
        RowBox[{"a", "=", 
         RowBox[{"Max", "[", 
          RowBox[{"e1", ",", 
