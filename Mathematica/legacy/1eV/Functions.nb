Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"LInttrapPk", "[", "f_", "]"}], "[", 
    RowBox[{"x1_", ",", "x2_", ",", "xpeak_"}], "]"}], "[", "n_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"xlist1", ",", "xlist2", ",", "tab"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xlist1", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"xpeak", "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"(", 
              FractionBox["x1", "xpeak"], ")"}], "^", 
             RowBox[{"(", 
              FractionBox["i", "n"], ")"}]}]}], " ", ")"}]}], "+", "x1"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"xlist2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"xpeak", "*", 
         RowBox[{
          RowBox[{"(", 
           FractionBox["x2", "xpeak"], ")"}], "^", 
          RowBox[{"(", 
           FractionBox["i", "n"], ")"}]}]}], " ", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"xlist1", "[", 
            RowBox[{"[", 
             RowBox[{"1", "+", "j"}], "]"}], "]"}], "-", 
           RowBox[{"xlist1", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "*", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"f", "[", 
            RowBox[{"xlist1", "[", 
             RowBox[{"[", 
              RowBox[{"1", "+", "j"}], "]"}], "]"}], "]"}], "+", 
           RowBox[{"f", "[", 
            RowBox[{"xlist1", "[", 
             RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"xlist2", "[", 
            RowBox[{"[", 
             RowBox[{"1", "+", "j"}], "]"}], "]"}], "-", 
           RowBox[{"xlist2", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "*", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"f", "[", 
            RowBox[{"xlist2", "[", 
             RowBox[{"[", 
              RowBox[{"1", "+", "j"}], "]"}], "]"}], "]"}], "+", 
           RowBox[{"f", "[", 
            RowBox[{"xlist2", "[", 
             RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "InitializeFunction",
 CellChangeTimes->{{3.938656579778785*^9, 3.938656731210105*^9}, 
