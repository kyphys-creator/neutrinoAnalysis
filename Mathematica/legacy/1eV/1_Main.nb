Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SampleIntByEdges", "[", "f_", "]"}], "[", 
   RowBox[{"edges_List", "?", "VectorQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"e", "=", "edges"}], "}"}], ",", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "e", "]"}], "<", "2"}], ",", 
       RowBox[{"Return", "[", 
        RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{"f", "[", "Ev", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"Ev", ",", 
           RowBox[{"e", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"e", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{
          RowBox[{"Length", "[", "e", "]"}], "-", "1"}]}], "}"}]}], "]"}]}]}],
    "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SampleIntByEdges", "::", "edges"}], "=", "\"\<`1`\>\""}], 
  ";"}]}], "Input",
 CellChangeTimes->{
  3.975459802528715*^9, {3.97940245482436*^9, 3.979402455536264*^9}},
 CellLabel->
  "In[628]:=",ExpressionUUID->"0977682c-73de-4419-b655-87b2034a5aea"],

Cell[BoxData[
 RowBox[{
  RowBox[{"makeEvEdgesByCount", "[", 
   RowBox[{"ev1_", ",", "ev2_", ",", 
    RowBox[{"nLow_Integer", "?", "Positive"}], ",", 
    RowBox[{"nHigh_Integer", "?", "Positive"}], ",", 
    RowBox[{"threshold_", ":", "2"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"lowEdges", ",", "highEdges"}], "}"}], ",", 
    RowBox[{"Which", "[", 
     RowBox[{
      RowBox[{"ev2", "<=", "threshold"}], ",", 
      RowBox[{"Subdivide", "[", 
       RowBox[{"ev1", ",", "ev2", ",", 
        RowBox[{"Max", "[", 
         RowBox[{"nLow", ",", "1"}], "]"}]}], "]"}], ",", 
      RowBox[{"ev1", ">=", "threshold"}], ",", 
      RowBox[{"Subdivide", "[", 
       RowBox[{"ev1", ",", "ev2", ",", 
        RowBox[{"Max", "[", 
         RowBox[{"nHigh", ",", "1"}], "]"}]}], "]"}], ",", "True", ",", 
      RowBox[{
       RowBox[{"lowEdges", "=", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"ev1", ",", "threshold", ",", 
          RowBox[{"Max", "[", 
           RowBox[{"nLow", ",", "1"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"highEdges", "=", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"threshold", ",", "ev2", ",", 
          RowBox[{"Max", "[", 
           RowBox[{"nHigh", ",", "1"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
        RowBox[{"lowEdges", ",", 
         RowBox[{"Rest", "[", "highEdges", "]"}]}], "]"}]}]}], " ", 
     RowBox[{"(*", 
      RowBox[{"NO", " ", "threshold", " ", "overlap"}], "*)"}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.980960808555643*^9, 3.98096085275524*^9}, {
